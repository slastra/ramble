# LiveKit Configuration
LIVEKIT_KEY=devkey
LIVEKIT_SECRET=secret
LIVEKIT_URL=ws://localhost:7880

# File Storage
FILE_STORAGE_MOUNT=./uploads

# Site URL for production
NUXT_PUBLIC_SITE_URL=https://lastra.us

# Ntfy Notifications (optional)
NTFY_URL=
NTFY_TOPIC=

# Your username (notifications won't be sent for messages from this user)
MY_USERNAME=

# Gemini API Configuration
# Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Ramble Daemon (optional)
NUXT_PUBLIC_DAEMON_URL=http://localhost:9001
NUXT_PUBLIC_DAEMON_ENABLED=true
